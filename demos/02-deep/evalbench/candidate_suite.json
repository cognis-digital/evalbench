{
  "name": "rag-answer-quality-v2-regressed",
  "defaults": {"weight": 1.0, "required": true},
  "cases": [
    {
      "id": "capital-of-france",
      "vars": {"q": "What is the capital of France?"},
      "output": "The capital of France is Paris.",
      "latency_ms": 190,
      "cost_usd": 0.0008,
      "assert": [
        {"type": "icontains", "value": "Paris"},
        {"type": "not-contains", "value": "London"},
        {"type": "word-count", "min": 4, "max": 40},
        {"type": "latency", "max": 500}
      ]
    },
    {
      "id": "json-weather",
      "vars": {"q": "Return today's weather as JSON"},
      "output": "{\"city\": \"Austin\", \"temp_f\": 78, \"condition\": \"foggy\", \"humidity\": 40}",
      "latency_ms": 230,
      "cost_usd": 0.0012,
      "assert": [
        {"type": "json-valid"},
        {"type": "json-schema", "schema": {
          "type": "object",
          "required": ["city", "temp_f", "condition"],
          "properties": {
            "city": {"type": "string", "minLength": 1},
            "temp_f": {"type": "integer", "minimum": -50, "maximum": 150},
            "condition": {"type": "string", "enum": ["sunny", "cloudy", "rain", "snow"]}
          },
          "additionalProperties": false
        }},
        {"type": "json-path", "path": "condition", "value": "sunny"}
      ]
    },
    {
      "id": "summary-match",
      "vars": {"q": "Summarize the password reset flow"},
      "output": "Use the emailed link to choose a new password after entering your email.",
      "latency_ms": 250,
      "cost_usd": 0.0011,
      "assert": [
        {"type": "similarity",
         "value": "Select Forgot Password, type your email, and use the emailed link to choose a new password.",
         "threshold": 0.5},
        {"type": "contains", "value": "email"}
      ]
    }
  ]
}
