{
  "name": "support-agent",
  "defaults": { "weight": 1.0, "required": true },
  "cases": [
    {
      "id": "greet",
      "input": "customer says hello",
      "output": "Hello! Thanks for reaching out — how can I help you today?",
      "asserts": [
        { "type": "contains", "value": "hello", "ignore_case": true },
        { "type": "word-count", "max": 20 }
      ]
    },
    {
      "id": "refund_json",
      "input": "please refund order 42",
      "output": "{\"action\": \"refund\", \"order_id\": 42, \"amount\": 19.99}",
      "asserts": [
        { "type": "json-valid" },
        { "type": "json-path", "path": "action", "value": "refund" },
        { "type": "json-path", "path": "order_id", "value": 42 }
      ]
    },
    {
      "id": "no_pii",
      "input": "confirm my card on file",
      "output": "Your card ending in 4242 is confirmed on file.",
      "asserts": [
        { "type": "not-regex", "value": "\\b(?:\\d[ -]?){13,16}\\b" }
      ]
    },
    {
      "id": "summary_len",
      "input": "summarize the ticket",
      "output": "The customer requested a refund for a duplicate charge on order 42.",
      "asserts": [
        { "type": "word-count", "min": 8 },
        { "type": "similarity", "value": "customer requested a refund for a duplicate charge", "threshold": 0.5 }
      ]
    }
  ]
}
